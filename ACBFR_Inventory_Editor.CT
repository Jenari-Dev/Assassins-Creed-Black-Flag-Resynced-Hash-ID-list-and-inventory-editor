  </Files>
  <CheatEntries>
    <CheatEntry>
      <ID>1</ID>
      <Description>"Attach to Game (Auto-Detect) | Cheat Table Made By JenAriDev"</Description>
      <Options moHideChildren="1"/>
      <VariableType>Auto Assembler Script</VariableType>
      <AssemblerScript>[ENABLE]
{$lua}
if syntaxcheck then return end
-- (auto-update checker removed for FearlessRevolution compliance: no network calls, no version fetch, no external links)

-- ---- universal attach (Steam / Ubisoft Connect = ACBlackFlag.exe, Ubisoft+ = ACBlackFlag_Plus.exe) ----
local EXE_STANDARD = "ACBlackFlag.exe"
local EXE_PLUS     = "ACBlackFlag_Plus.exe"
local detectedExe = nil
if getProcessIDFromProcessName(EXE_STANDARD) then openProcess(EXE_STANDARD); detectedExe=EXE_STANDARD
elseif getProcessIDFromProcessName(EXE_PLUS) then openProcess(EXE_PLUS); detectedExe=EXE_PLUS
else print("Black Flag process not found - launch the game first.") end
if detectedExe then
  local base = getAddress(detectedExe)
  print("Attached to "..detectedExe.."  base="..(base and string.format("%X",base) or "?"))
  if base and base~=0 then
    local other = (detectedExe==EXE_STANDARD) and EXE_PLUS or EXE_STANDARD
    pcall(unregisterSymbol, other); pcall(registerSymbol, other, base, true)
  end
end
-- (no update check on attach - removed for FRF compliance)
{$asm}

[DISABLE]
</AssemblerScript>
      <CheatEntries>
        <CheatEntry>
          <ID>9013</ID>
          <Description>"Version 0.1.3"</Description>
          <GroupHeader>1</GroupHeader>
        </CheatEntry>
        <CheatEntry>
          <ID>23</ID>
          <Description>"Player Options"</Description>
          <Options moHideChildren="1"/>
          <GroupHeader>1</GroupHeader>
          <CheatEntries>
            <CheatEntry>
              <ID>22</ID>
              <Description>"God Mode"</Description>
              <VariableType>Auto Assembler Script</VariableType>
              <AssemblerScript>[ENABLE]
aobscanmodule(bfGodHP,ACBlackFlag.exe,C5 FA 11 81 98 01 00 00 C5 FA 11 40 18)
alloc(bfGodCave,256,bfGodHP)
label(bfGodRet)
registersymbol(bfGodHP)

bfGodCave:
vmaxss xmm0,xmm0,[rcx+198]
vmovss [rcx+198],xmm0
jmp bfGodRet

bfGodHP:
jmp bfGodCave
nop 3
bfGodRet:

[DISABLE]
bfGodHP:
db C5 FA 11 81 98 01 00 00
dealloc(bfGodCave)
unregistersymbol(bfGodHP)
</AssemblerScript>
            </CheatEntry>
          </CheatEntries>
        </CheatEntry>
        <CheatEntry>
          <ID>10</ID>
          <Description>"Inventory Options"</Description>
          <Options moHideChildren="1" moManualExpandCollapse="1"/>
          <GroupHeader>1</GroupHeader>
          <CheatEntries>
            <CheatEntry>
              <ID>20</ID>
              <Description>"Universal Resource (add on use / consume / buy)"</Description>
              <Options moHideChildren="1"/>
              <VariableType>Auto Assembler Script</VariableType>
              <AssemblerScript>[ENABLE]
alloc(bfgURcave,0x400,ACBlackFlag.exe+F4DE0B)
alloc(bfgUR_value,4)
registersymbol(bfgUR_value)
label(bfgUR_ret)
label(bfgURhook)

bfgUR_value:
dd 0

bfgURcave:
bfgURhook:
mov edx,[rbx+r14+10]
add edx,[bfgUR_value]
mov [rbx+r14+10],edx
jmp bfgUR_ret

ACBlackFlag.exe+F4DE0B:
jmp bfgURhook
bfgUR_ret:

[DISABLE]
ACBlackFlag.exe+F4DE0B:
db 42 89 54 33 10

unregistersymbol(bfgUR_value)
dealloc(bfgUR_value)
dealloc(bfgURcave)
</AssemblerScript>
              <CheatEntries>
                <CheatEntry>
                  <ID>21</ID>
                  <Description>"Set value / how it works  (click me)"</Description>
                  <VariableType>Auto Assembler Script</VariableType>
                  <AssemblerScript>[ENABLE]
{$lua}
if syntaxcheck then return end
local function bfUntick(id)
  local t=createTimer(nil,false); t.Interval=80
  t.OnTimer=function(tm) tm.destroy(); pcall(function()
    local r=getAddressList():getMemoryRecordByID(id); if r then r.Active=false end end) end
  t.Enabled=true
end
local sym="bfgUR_value"
if not getAddressSafe(sym) then
  showMessage("Enable the parent \"Universal Resource\" cheat first, then set the amount.")
else
  local cur=readInteger(sym)
  local s=inputQuery("Universal Resource",
    "Whenever you USE / CONSUME / BUY an item, its amount is set to (current + this value) instead of dropping.\n\n    0  =  infinite  (amounts never decrease)\n    N  =  add N to that item's total each use\n\nEnter a value:",
    tostring(cur or 0))
  if s and tonumber(s) then
    local n=math.floor(tonumber(s)); if n&lt;0 then n=0 end
    writeInteger(sym,n)
    showMessage(n==0 and "Set to 0  --  amounts are now infinite (they never decrease)." or ("Set to "..n.."  --  adds "..n.." to that item's total each use."))
  end
end
bfUntick(21)
{$asm}

[DISABLE]
{$lua}
if syntaxcheck then return end
{$asm}
</AssemblerScript>
                </CheatEntry>
              </CheatEntries>
            </CheatEntry>
            <CheatEntry>
              <ID>11</ID>
              <Description>"Inventory Editor"</Description>
              <Options moHideChildren="1" moActivateChildrenAsWell="1"/>
              <VariableType>Auto Assembler Script</VariableType>
              <AssemblerScript>[ENABLE]
{$lua}
if syntaxcheck then return end
BFG = BFG or {}
BFG.base = getAddress("ACBlackFlag.exe")
local base = BFG.base
local function say(s) end
local function heap(p) return p and p&gt;0x100000 and p&lt;0x7FF000000000 end  -- v0.1.5: floor lowered from 0x10000000000 (1TB). Some users' game heap sits at LOW addresses (e.g. 0x3980101B0 ~15GB, 0x140E862EB0 ~86GB) that the old 1TB floor wrongly rejected -> looksLikeMgr failed for every candidate -> "no inventory manager found". Counts/flags are all &lt; 0x100000, and the AOB-resolved vt1 vtable check still does the real validation.
local function le8(v) local t={} for i=0,7 do t[#t+1]=string.format("%02X",(v&gt;&gt;(8*i))&amp;0xFF) end return table.concat(t," ") end

-- ---------- AOB address resolver ----------
function BFG.resolveAOB()
  local sz = 0x1E1E5000
  pcall(function() if getModuleSize then sz = getModuleSize("ACBlackFlag.exe") or sz end end)
  local function scan(sig)
    local ms = createMemScan()
    local ok = pcall(function()
      ms.firstScan(soExactValue, vtByteArray, rtRounded, sig, nil, base, base+sz, "*W*C*X", fsmNotAligned, "", false,false,false,false)
      ms.waitTillDone()
    end)
    local addr=nil
    if ok then local fl=createFoundList(ms); fl.initialize(); if fl.Count&gt;0 then addr=tonumber(fl.Address[0],16) end fl.destroy() end
    ms.destroy(); return addr
  end
  local A={}
  A.giveItem = scan("41 57 41 56 41 54 56 57 55 53 48 83 EC 50 49 89 D6")
  A.tick     = scan("C5 FA 11 87 ?? ?? ?? ?? 0F B6 86 ?? ?? ?? ??")
  A.alloc    = scan("41 56 56 57 53 48 83 EC 38 48 89 CE 48 8B 09")
  A.initDef  = scan("41 57 41 56 41 55 41 54 56 57 55 53 48 83 EC 28 48 89 CE 48 8B 3A 48 8D 2D ?? ?? ?? ??")
  local pr = scan("48 8B 0D ?? ?? ?? ?? 48 85 C9 48 0F 45 C1 E9 ?? ?? ?? ?? 49 8B 07 BA 88 00 00 00 4C 89 F9 41 B8 08 00 00 00 45 31 C9 FF 50 ?? E9 ?? ?? ?? ?? 48 89 C3")
  A.pool   = pr  and (pr  + 7 + readInteger(pr+3))
  local tr = scan("8B 05 ?? ?? ?? ?? 65 48 8B 0C 25 ?? ?? ?? ?? 48 8B 04 C1 48 8D 88 ?? ?? ?? ?? 48 89 4C 24 ?? 4C 8D B0 ?? ?? ?? ?? 49 BF F8 FF FF FF 07 00 00 00")
  A.tlsIdx = tr  and (tr  + 6 + readInteger(tr+2))
  local v3 = scan("4C 8D 15 ?? ?? ?? ?? 41 B8 FF 3F 00 00 C4 E2 79 18 35 ?? ?? ?? ??")
  A.vt3    = v3  and (v3  + 7 + readInteger(v3+3))
  local v12 = scan("48 8D 15 ?? ?? ?? ?? 49 89 16 48 8D 15 ?? ?? ?? ?? 49 89 56 10")
  A.vt1 = v12 and (v12 + 7  + readInteger(v12+3))
  A.vt2 = v12 and (v12 + 17 + readInteger(v12+13))
  if not (A.giveItem and A.tick and A.alloc and A.initDef and A.pool and A.tlsIdx and A.vt1 and A.vt2 and A.vt3) then return nil end
  return A
end

-- gsub every ACBlackFlag.exe+RVA token in an AA template with its AOB-resolved absolute hex
local function aobize(tpl, A)
  local map = {
    ["ACBlackFlag%.exe%+1AD493"]  = A.tick+8,     -- tick return (site+8)
    ["ACBlackFlag%.exe%+1AD48B"]  = A.tick,       -- tick site
    ["ACBlackFlag%.exe%+FE8BE6"]  = A.giveItem+6, -- GiveItem+6 pass-through
    ["ACBlackFlag%.exe%+FE8BE0"]  = A.giveItem,
    ["ACBlackFlag%.exe%+AB25820"] = A.tlsIdx,
    ["ACBlackFlag%.exe%+AF08C78"] = A.pool,
    ["ACBlackFlag%.exe%+41CCE40"] = A.alloc,
    ["ACBlackFlag%.exe%+93870D0"] = A.vt1,
    ["ACBlackFlag%.exe%+9281458"] = A.vt2,
    ["ACBlackFlag%.exe%+AF0C998"] = A.vt3,
    ["ACBlackFlag%.exe%+4319E0"]  = A.initDef,
  }
  for pat,val in pairs(map) do tpl = tpl:gsub(pat, string.format("%X", val)) end
  return tpl
end

-- ---------- the give hook (mgr capture + delivery fallback) ----------
function BFG.installHook()
  local A = BFG.aob or BFG.resolveAOB()
  if not A then say("AOB resolve failed"); return false end
  BFG.aob = A
  pcall(function() writeBytes(A.giveItem, 0x41,0x57,0x41,0x56,0x41,0x54) end)
  pcall(function() autoAssemble("dealloc(bfgHook)\nunregistersymbol(bfgHook)") end)
  local stub = [[
alloc(bfgHook,8192,ACBlackFlag.exe+FE8BE0)
label(bfgMgr) label(bfgNatReq) label(bfgFlag) label(bfgDone) label(bfgRec) label(bfgItem) label(bfgReq) label(bfgTargetMgr) label(bfgQCount) label(bfgQueue) label(bfgTID) label(bfgRA) label(bfgStack) label(bfgCosStore)
label(ppool) label(qloop) label(qnext) label(qdone) label(pass) label(qReg)
registersymbol(bfgHook)
bfgHook:
  mov [bfgMgr],rcx
  mov [bfgNatReq],rdx
  push rax
  mov rax,gs:[48]
  mov [bfgTID],rax
  mov rax,[rsp+8]
  mov [bfgRA],rax
  pop rax
  push rsi
  push rdi
  push rcx
  cld
  lea rsi,[rsp+18]
  lea rdi,[bfgStack]
  mov ecx,40
  rep movsq
  pop rcx
  pop rdi
  pop rsi
  mov eax,[bfgFlag]
  test eax,eax
  je pass
  xor eax,eax
  mov [bfgFlag],eax
  push r15
  push r13
  push rax
  push rcx
  push rdx
  push r8
  push r9
  push r10
  push r11
  push r14
  pushfq
  xor r15,r15
  lea r13,[bfgQueue]
qloop:
  mov eax,[bfgQCount]
  cmp r15d,eax
  jge qdone
  mov rax,[r13+r15*8]
  mov [bfgRec],rax
  mov r8,gs:[58]
  mov ecx,[ACBlackFlag.exe+AB25820]
  mov r8,[r8+rcx*8]
  mov rax,[r8+1C60]
  test rax,rax
  jnz ppool
  mov rax,[ACBlackFlag.exe+AF08C78]
ppool:
  mov rcx,rax
  mov edx,88
  mov r8d,8
  call ACBlackFlag.exe+41CCE40
  test rax,rax
  jz qnext
  mov r14,rax
  xor eax,eax
  mov [r14+08],eax
  mov eax,[r14+38]
  and eax,80000000
  or eax,0000C000
  mov [r14+38],eax
  mov eax,[r14+20]
  and eax,80000000
  or eax,0000C000
  mov [r14+20],eax
  xor eax,eax
  mov [r14+18],rax
  vxorps xmm0,xmm0,xmm0
  vmovups [r14+28],xmm0
  mov rax,ACBlackFlag.exe+93870D0
  mov [r14+00],rax
  mov rax,ACBlackFlag.exe+9281458
  mov [r14+10],rax
  mov rax,ACBlackFlag.exe+AF0C998
  mov [r14+40],rax
  mov [r14+58],rax
  xor eax,eax
  mov [r14+60],eax
  mov eax,[r14+6C]
  and eax,80000000
  or eax,0000C000
  mov [r14+6C],eax
  xor eax,eax
  mov [r14+64],rax
  mov [r14+70],al
  mov rax,ACBlackFlag.exe+AF0C998
  mov [r14+78],rax
  vmovups [r14+48],xmm0
  mov eax,FFFFFFFF
  db F2 49 0F 38 F1 C6
  not eax
  mov [r14+80],eax
  mov rcx,r14
  lea rdx,[bfgRec]
  call ACBlackFlag.exe+4319E0
  mov [bfgItem],r14
  mov [bfgReq+08],r14
  mov rax,[bfgCosStore]
  test rax,rax
  jz qReg
  lea rcx,[rax+10]
  lea rdx,[bfgRec]
  mov r8d,1
  sub rsp,20
  call ACBlackFlag.exe+374E0
  add rsp,20
  jmp qnext
qReg:
  mov rcx,[bfgTargetMgr]
  test rcx,rcx
  jz qnext
  lea rdx,[bfgReq]
  sub rsp,20
  call ACBlackFlag.exe+FE8BE0
  add rsp,20
qnext:
  inc r15
  jmp qloop
qdone:
  xor eax,eax
  mov [bfgQCount],eax
  mov eax,1
  mov [bfgDone],eax
  popfq
  pop r14
  pop r11
  pop r10
  pop r9
  pop r8
  pop rdx
  pop rcx
  pop rax
  pop r13
  pop r15
pass:
  push r15
  push r14
  push r12
  jmp ACBlackFlag.exe+FE8BE6
bfgMgr:
  dq 0
bfgNatReq:
  dq 0
bfgFlag:
  dd 0
bfgDone:
  dd 0
bfgRec:
  dq 0
bfgItem:
  dq 0
bfgTargetMgr:
  dq 0
bfgReq:
  dd 3F800000
  dd 0
  dq 0
  dq 0
  dd 01010101
  dd 0
bfgQCount:
  dd 0
  dd 0
bfgQueue:
  dq 0
bfgTID:
  dq 0
bfgRA:
  dq 0
bfgStack:
  dq 0
bfgCosStore:
  dq 0
]]
  stub = aobize(stub, A)
  local ok,err = autoAssemble(stub)
  local H = getAddressSafe("bfgHook")
  if not ok or not H then say("hook assemble failed: "..tostring(err)); return false end
  local b = readBytes(H,3,true)
  if not (b[1]==0x48 and b[2]==0x89 and b[3]==0x0D) then say("hook layout unexpected"); return false end
  local rel = readInteger(H+3); if rel&gt;=0x80000000 then rel=rel-0x100000000 end
  local m = (H+7+rel) &amp; 0xFFFFFFFFFFFFFFFF
  BFG.A = { hook=H, mgr=m, natreq=m+0x08, flag=m+0x10, done=m+0x14, rec=m+0x18, item=m+0x20, targetMgr=m+0x28, req=m+0x30, qcount=m+0x50, queue=m+0x58, tid=m+0x60, ra=m+0x68, stack=m+0x70, cosStore=m+0x78 }
  writeInteger(BFG.A.req+0x00, 0x3F800000)
  writeInteger(BFG.A.req+0x04, 0)
  writeQword  (BFG.A.req+0x08, 0)
  writeQword  (BFG.A.req+0x10, 0)
  writeInteger(BFG.A.req+0x18, 0x01010101)
  writeInteger(BFG.A.req+0x1C, 0)
  writeInteger(BFG.A.flag,0); writeInteger(BFG.A.done,0); writeQword(BFG.A.targetMgr,0); writeInteger(BFG.A.qcount,0)
  local give=A.giveItem
  local pre=readBytes(give,6,true)
  if not (pre[1]==0x41 and pre[2]==0x57 and pre[3]==0x41 and pre[4]==0x56 and pre[5]==0x41 and pre[6]==0x54) then
    say("GiveItem prologue not as expected -- ABORT"); return false
  end
  local r2=(H-(give+5))&amp;0xFFFFFFFF
  writeBytes(give,0xE9,r2&amp;0xFF,(r2&gt;&gt;8)&amp;0xFF,(r2&gt;&gt;16)&amp;0xFF,(r2&gt;&gt;24)&amp;0xFF,0x90)
  return true
end

-- ---------- per-frame tick delivery ----------
-- Hooks the health tick. Shares bfgHook's data section (addresses from BFG.A).
-- The flag is cleared after the loop so the pump can't refill the queue mid-read.
function BFG.installTick()
  local A = BFG.aob; local D = BFG.A
  if not (A and D) then say("installTick: no aob/data"); return false end
  pcall(function() writeBytes(A.tick, 0xC5,0xFA,0x11,0x87,0x28,0x01,0x00,0x00) end)
  pcall(function() autoAssemble("dealloc(bfgTick)\nunregistersymbol(bfgTick)") end)
  local tpl = [[
alloc(bfgTick,8192,ACBlackFlag.exe+1AD48B)
label(bfgTGpass) label(bfgTGret) label(bfgTLoop) label(bfgTNext) label(bfgTDone) label(bfgTPool) label(bfgTReg)
registersymbol(bfgTick)
bfgTick:
  vmovss [rdi+00000128],xmm0
  push rax
  mov rax,__FLAG__
  cmp dword [rax],0
  je bfgTGpass
  pop rax
  push rbp
  mov rbp,rsp
  push rbx
  push rsi
  push rdi
  push r12
  push r13
  push r14
  push r15
  push rax
  push rcx
  push rdx
  push r8
  push r9
  push r10
  push r11
  pushfq
  and rsp,-10
  sub rsp,60
  vmovups [rsp+00],xmm0
  vmovups [rsp+10],xmm1
  vmovups [rsp+20],xmm2
  vmovups [rsp+30],xmm3
  vmovups [rsp+40],xmm4
  vmovups [rsp+50],xmm5
  xor r15,r15
bfgTLoop:
  mov rax,__QCOUNT__
  mov eax,[rax]
  cmp r15d,eax
  jge bfgTDone
  mov rax,__QUEUE__
  mov rax,[rax+r15*8]
  mov rcx,__REC__
  mov [rcx],rax
  mov r8,gs:[58]
  mov ecx,[ACBlackFlag.exe+AB25820]
  mov r8,[r8+rcx*8]
  mov rax,[r8+1C60]
  test rax,rax
  jnz bfgTPool
  mov rax,[ACBlackFlag.exe+AF08C78]
bfgTPool:
  mov rcx,rax
  mov edx,88
  mov r8d,8
  sub rsp,20
  call ACBlackFlag.exe+41CCE40
  add rsp,20
  test rax,rax
  jz bfgTNext
  mov r14,rax
  xor eax,eax
  mov [r14+08],eax
  mov eax,[r14+38]
  and eax,80000000
  or eax,0000C000
  mov [r14+38],eax
  mov eax,[r14+20]
  and eax,80000000
  or eax,0000C000
  mov [r14+20],eax
  xor eax,eax
  mov [r14+18],rax
  vxorps xmm0,xmm0,xmm0
  vmovups [r14+28],xmm0
  mov rax,ACBlackFlag.exe+93870D0
  mov [r14+00],rax
  mov rax,ACBlackFlag.exe+9281458
  mov [r14+10],rax
  mov rax,ACBlackFlag.exe+AF0C998
  mov [r14+40],rax
  mov [r14+58],rax
  xor eax,eax
  mov [r14+60],eax
  mov eax,[r14+6C]
  and eax,80000000
  or eax,0000C000
  mov [r14+6C],eax
  xor eax,eax
  mov [r14+64],rax
  mov [r14+70],al
  mov rax,ACBlackFlag.exe+AF0C998
  mov [r14+78],rax
  vmovups [r14+48],xmm0
  mov eax,FFFFFFFF
  db F2 49 0F 38 F1 C6
  not eax
  mov [r14+80],eax
  mov rcx,r14
  mov rdx,__REC__
  sub rsp,20
  call ACBlackFlag.exe+4319E0
  add rsp,20
  mov rcx,__ITEM__
  mov [rcx],r14
  mov rcx,__REQ__
  mov [rcx+08],r14
  mov rax,__COSSTORE__
  mov rax,[rax]
  test rax,rax
  jz bfgTReg
  lea rcx,[rax+10]
  mov rdx,__REC__
  mov r8d,1
  sub rsp,20
  call ACBlackFlag.exe+374E0
  add rsp,20
  jmp bfgTNext
bfgTReg:
  mov rax,__TARGETMGR__
  mov rcx,[rax]
  test rcx,rcx
  jz bfgTNext
  mov rdx,__REQ__
  sub rsp,20
  call ACBlackFlag.exe+FE8BE0
  add rsp,20
bfgTNext:
  inc r15
  jmp bfgTLoop
bfgTDone:
  mov rax,__QCOUNT__
  mov dword [rax],0
  mov rax,__DONE__
  mov dword [rax],1
  mov rax,__FLAG__
  mov dword [rax],0
  vmovups xmm0,[rsp+00]
  vmovups xmm1,[rsp+10]
  vmovups xmm2,[rsp+20]
  vmovups xmm3,[rsp+30]
  vmovups xmm4,[rsp+40]
  vmovups xmm5,[rsp+50]
  lea rsp,[rbp-78]
  popfq
  pop r11
  pop r10
  pop r9
  pop r8
  pop rdx
  pop rcx
  pop rax
  pop r15
  pop r14
  pop r13
  pop r12
  pop rdi
  pop rsi
  pop rbx
  pop rbp
  jmp bfgTGret
bfgTGpass:
  pop rax
bfgTGret:
  jmp ACBlackFlag.exe+1AD493
ACBlackFlag.exe+1AD48B:
  jmp bfgTick
  nop 3
]]
  tpl = tpl:gsub("__FLAG__", string.format("%X",D.flag))
           :gsub("__QCOUNT__", string.format("%X",D.qcount))
           :gsub("__QUEUE__", string.format("%X",D.queue))
           :gsub("__REC__", string.format("%X",D.rec))
           :gsub("__ITEM__", string.format("%X",D.item))
           :gsub("__REQ__", string.format("%X",D.req))
           :gsub("__TARGETMGR__", string.format("%X",D.targetMgr))
           :gsub("__COSSTORE__", string.format("%X",D.cosStore))
           :gsub("__DONE__", string.format("%X",D.done))
  tpl = aobize(tpl, A)
  local ok,err = autoAssemble(tpl)
  if not ok or not getAddressSafe("bfgTick") then say("tick assemble failed: "..tostring(err)); return false end
  return true
end

function BFG.uninstallHook()
  if BFG.aob and BFG.aob.tick then pcall(function() writeBytes(BFG.aob.tick, 0xC5,0xFA,0x11,0x87,0x28,0x01,0x00,0x00) end) end
  if BFG.aob and BFG.aob.giveItem then pcall(function() writeBytes(BFG.aob.giveItem, 0x41,0x57,0x41,0x56,0x41,0x54) end) end
  pcall(function() autoAssemble("dealloc(bfgTick)\nunregistersymbol(bfgTick)\ndealloc(bfgHook)\nunregistersymbol(bfgHook)") end)
  BFG.A=nil
end

-- ---------- auto-find the real player inventory manager (version-independent) ----------
-- Validate managers via the AOB-resolved item vtable (vt1); LEARN the per-build comparator and
-- catalog vtable (CVT) from a known-good manager so a game patch that shifts data sections (which
-- moves these addresses but not the AOB'd functions) can no longer break inventory detection.
local function inmod(a) return a and a&gt;=base and a&lt;base+0x1F000000 end
local function itemOK(it)
  if not heap(it) then return false end
  local vt1 = BFG.aob and BFG.aob.vt1
  if vt1 then return readQword(it)==vt1 end                 -- vt1 is AOB-resolved = version-independent
  local rec=readQword(it+0x40); if not heap(rec) then return false end
  return heap(readQword(rec))                               -- structural fallback if vt1 unavailable
end
local function looksLikeMgr(M)
  if not heap(M) then return false end
  if not pcall(readQword,M+8) then return false end
  local arr=readQword(M+0x14); if not heap(arr) then return false end
  local cnt=readInteger(M+0x1C); if not cnt then return false end
  cnt=cnt&amp;0x3FFF; if cnt&lt;1 or cnt&gt;=4096 then return false end
  local good,tot=0,0
  for i=0,math.min(cnt,12)-1 do
    local P=readQword(arr+i*0x18)
    if heap(P) then local it=readQword(P)
      if heap(it) then tot=tot+1; if itemOK(it) then good=good+1 end end end
  end
  return tot&gt;0 and good&gt;=1 and good&gt;=tot-1
end
local function isStrict(M)
  local ok,gate=pcall(readQword,M+8); if not ok or gate~=0 then return false end
  return readQword(M+0x88)==M+0xB0
end
-- learn the per-build comparator + catalog vtable from a manager we trust (captured or found)
local function learnFrom(M)
  local c=readQword(M+0x20); if inmod(c) then BFG.comparator=c end
  local arr=readQword(M+0x14)
  if heap(arr) then
    for i=0,11 do
      local P=readQword(arr+i*0x18)
      if heap(P) then local it=readQword(P)
        if heap(it) then local rec=readQword(it+0x40)
          if heap(rec) then local def=readQword(rec)
            if heap(def) then local v=readQword(def); if inmod(v) then BFG.cvt=v; break end end end end end
    end
  end
end
function BFG.findMgr()
  -- learn the per-build comparator + CVT from the game-captured manager (any size = version-independent)
  local cap = (BFG.A and BFG.A.mgr) and readQword(BFG.A.mgr) or nil
  if cap and looksLikeMgr(cap) then learnFrom(cap) end
  -- fast path: a previously chosen main bag that is still valid
  if BFG.mgr and looksLikeMgr(BFG.mgr) then return BFG.mgr end
  -- the player's MAIN bag is the LARGEST item-manager. The captured manager can drift into a small
  -- sub-inventory (currency/quest reward), so it is used only to learn addresses + break same-size twin ties.
  local comp = BFG.comparator or (base+0x4B0F010)
  local s=AOBScan(le8(comp),"+W-X")
  if not s then
    if cap and looksLikeMgr(cap) then BFG.mgr=cap; return cap end
    return nil
  end
  local sb,sc,ab,ac=nil,0,nil,0
  for i=0,s.Count-1 do
    local M=tonumber(s[i],16)-0x20
    local okc,cnt=pcall(function() return readInteger(M+0x1C)&amp;0x3FFF end)
    if okc and cnt and cnt&gt;0 and looksLikeMgr(M) then
      if cnt&gt;ac then ab=M; ac=cnt end
      if cnt&gt;sc and isStrict(M) then sb=M; sc=cnt end
    end
  end
  s.destroy()
  local pick = sb or ab
  if pick and cap and looksLikeMgr(cap) then
    local ok1,cc=pcall(function() return readInteger(cap+0x1C)&amp;0x3FFF end)
    local ok2,pc=pcall(function() return readInteger(pick+0x1C)&amp;0x3FFF end)
    if ok1 and ok2 and cc&gt;=pc then pick=cap end   -- captured mgr is a same-size-or-bigger twin: trust the game's target
  end
  BFG.mgr = pick
  if pick then learnFrom(pick) end
  return BFG.mgr
end
-- paste-back diagnostic for users who still report "no manager found"
function BFG.diagnose()
  local L={"=== ACBFR giver diagnose ==="}
  L[#L+1]="base="..string.format("%X",base)
  local A=BFG.aob
  L[#L+1]="AOBs resolved: "..(A and "YES" or "NO")..(A and ("  vt1="..(A.vt1 and string.format("%X",A.vt1) or "MISSING")) or "")
  L[#L+1]="hook="..(getAddressSafe("bfgHook") and "yes" or "NO").."  tick="..(getAddressSafe("bfgTick") and "yes" or "NO")
  local cap=(BFG.A and BFG.A.mgr) and readQword(BFG.A.mgr) or 0
  L[#L+1]="captured mgr: "..(cap~=0 and (string.format("%X",cap).." valid="..tostring(looksLikeMgr(cap))) or "NONE yet")
  L[#L+1]="learned comparator="..(BFG.comparator and string.format("rva %X",BFG.comparator-base) or "no").."  CVT="..(BFG.cvt and string.format("rva %X",BFG.cvt-base) or "no")
  local comp=BFG.comparator or (base+0x4B0F010)
  local s=AOBScan(le8(comp),"+W-X"); local hits=s and s.Count or -1; local mgrs=0
  if s then for i=0,s.Count-1 do if looksLikeMgr(tonumber(s[i],16)-0x20) then mgrs=mgrs+1 end end s.destroy() end
  L[#L+1]="comparator scan hits="..hits.."  valid item-mgrs="..mgrs
  local M=BFG.findMgr()
  L[#L+1]="findMgr()="..(M and string.format("%X cnt %d",M,readInteger(M+0x1C)&amp;0x3FFF) or "NIL")
  local out=table.concat(L,"\n"); print(out); showMessage(out); return out
end
-- ---------- ship-cosmetic store (the Jackdaw customize-menu registry) ----------
-- The customize menu reads a SEPARATE store, disjoint from the item bag. Ship cosmetics given the
-- normal way land in the bag and never show; they must be inserted into this store. The store is
-- identified by its type pointer at M+0xB0; the largest manager of that type is the ship store.
-- is this hash a ship-customization item (routes to the store, not the bag)? uses the editor's category data
function BFG.isCosmetic(hash)  -- v0.1.4: Jackdaw-store routing RE-ENABLED. Ship Cosmetics + Crew Outfits -&gt; customize-menu store. Crash fixed via done-handshake pump + tick-only delivery + store dedup (see startPump / the hook patch below).
  if not BFG.cosSet or BFG.cosSetEmpty then
    BFG.cosSet={}; BFG.cosSetEmpty=true
    if type(gvItems)=="table" then
      for _,cat in ipairs({"Ship Cosmetic","Crew Outfit"}) do
        if gvItems[cat] then for _,it in ipairs(gvItems[cat]) do BFG.cosSet[it.hash:upper()]=true; BFG.cosSetEmpty=false end end
      end
    end
  end
  local key = (type(hash)=="string") and hash:upper() or string.format("%016X",hash)
  return BFG.cosSet[key]==true
end
function BFG.findCosmeticStore()
  local ST = BFG.storeType or (base+0x92901D8)
  if BFG.cosStore then
    local ok,v=pcall(function() return readQword(BFG.cosStore+0xB0)==ST and readQword(BFG.cosStore+0x20)==base+0x4B0F010 end)
    if ok and v then return BFG.cosStore end
  end
  local best,bestcnt=nil,0
  local s=AOBScan(le8(base+0x4B0F010),"+W-X")
  if s then
    for i=0,s.Count-1 do
      local M=tonumber(s[i],16)-0x20
      local ok,match=pcall(function() return readQword(M+0x20)==base+0x4B0F010 and readQword(M+0xB0)==ST end)
      if ok and match then
        local c=readInteger(M+0x1C)&amp;0x3FFF
        if c&gt;bestcnt and c&lt;8192 then best=M; bestcnt=c end
      end
    end
    s.destroy()
  end
  BFG.cosStore=best; return best
end
function BFG.testCos(hash)
  local st=BFG.findCosmeticStore(); if not st then return "no cosmetic store found" end
  local rec=BFG.resolveRecord(hash); if not rec then return "no record for "..tostring(hash) end
  writeQword(BFG.A.cosStore, st)
  writeQword(BFG.A.queue, rec)
  writeInteger(BFG.A.qcount, 1)
  writeInteger(BFG.A.done, 0)
  writeInteger(BFG.A.flag, 1)
  return string.format("armed cosmetic into store %X -- open/refresh the Jackdaw customize menu", st)
end

-- ---------- hash -&gt; resident catalog record ----------
BFG.recCache = BFG.recCache or {}
local function recRegion()
  local M=BFG.findMgr(); if not M then return nil end
  local arr=readQword(M+0x14); local P=arr and readQword(arr)
  local T=(P and P&gt;0x10000000000) and readQword(P) or nil
  local rr=T and readQword(T+0x40)
  if rr and rr&gt;0x10000000000 then local lo=rr &amp; 0xFFFFF0000000; return lo, lo+0x40000000 end
  return nil
end
local function scanRec(hash, lo, hi)
  local CVT=BFG.cvt or (base+0x93875C0); local rec
  local ms=createMemScan(); ms.setOnlyOneResult(false)
  pcall(function()
    if lo then ms.firstScan(soExactValue,vtByteArray,rtRounded,le8(hash),nil,lo,hi,"+W-X",fsmNotAligned,"",true,false,false,false)
    else ms.firstScan(soExactValue,vtByteArray,rtRounded,le8(hash),nil,0,0x7fffffffffff,"+W-X",fsmNotAligned,"",true,false,false,false) end
    ms.waitTillDone(); local fl=createFoundList(ms); fl.initialize()
    for i=0,fl.Count-1 do local r=tonumber(fl.Address[i],16)-0x10
      local ok,cd=pcall(readQword,r); local ok2,bb=pcall(readBytes,r+0x0B,1,false)
      if ok and ok2 and cd and cd&gt;0x10000 then local ok3,vt=pcall(readQword,cd)
        if ok3 and vt==CVT and bb and (bb&amp;0x80)~=0 then rec=r break end end end
    fl.destroy()
  end); ms.destroy(); return rec
end
BFG.recIndex = BFG.recIndex
BFG.indexing = false
function BFG.buildIndex()
  if BFG.indexing or BFG.recIndex then return end
  BFG.indexing=true
  createThread(function()
    local CVT=BFG.cvt or (base+0x93875C0); local idx={}
    pcall(function()
      local ms=createMemScan(); ms.setOnlyOneResult(false)
      ms.firstScan(soExactValue,vtQword,rtRounded,string.format("%X",CVT),nil,0,0x7fffffffffff,"+W-X",fsmAligned,"",true,false,false,false)
      ms.waitTillDone(); local fl=createFoundList(ms); fl.initialize()
      local lo,hi
      for i=0,fl.Count-1 do local a=tonumber(fl.Address[i],16); if not lo or a&lt;lo then lo=a end; if not hi or a&gt;hi then hi=a end end
      fl.destroy(); ms.destroy()
      if lo then
        local m2=createMemScan(); m2.setOnlyOneResult(false)
        m2.firstScan(soValueBetween,vtQword,rtRounded,string.format("%X",lo),string.format("%X",hi),0,0x7fffffffffff,"+W-X",fsmAligned,"",true,false,false,false)
        m2.waitTillDone(); local f2=createFoundList(m2); f2.initialize()
        for i=0,f2.Count-1 do local r=tonumber(f2.Address[i],16)
          local ok,cd=pcall(readQword,r); if ok and cd and cd&gt;=lo and cd&lt;=hi then local ok2,vt=pcall(readQword,cd)
            if ok2 and vt==CVT then local ok3,b=pcall(readBytes,r+0x0B,1,false)
              if ok3 and b and (b&amp;0x80)~=0 then idx[readQword(r+0x10)]=r end end end end
        f2.destroy(); m2.destroy()
      end
    end)
    BFG.recIndex=idx; BFG.indexing=false
  end)
end
function BFG.resolveRecord(hash)
  if type(hash)=="string" then hash=tonumber(hash,16) end
  if BFG.recIndex and BFG.recIndex[hash] then return BFG.recIndex[hash] end
  if BFG.recCache[hash] then return BFG.recCache[hash] end
  local lo,hi=recRegion()
  local rec = lo and scanRec(hash,lo,hi)
  if not rec then rec=scanRec(hash,nil,nil) end
  if rec then BFG.recCache[hash]=rec end
  return rec
end

-- ---------- non-blocking delivery queue ----------
BFG.q = BFG.q or {}
BFG.cq = BFG.cq or {}
function BFG.startPump()
  if BFG.pumpTimer then return end
  BFG.stuck=0
  writeInteger(BFG.A.done,1)   -- v0.1.4: allow the first arm (done-handshake)
  BFG.pumpTimer=createTimer(getMainForm()); BFG.pumpTimer.Interval=20
  BFG.pumpTimer.OnTimer=function(tm)
    if not (BFG.A and getAddressSafe("bfgHook")) then return end
    if readInteger(BFG.A.flag)~=0 then
      -- an item is armed but the tick has not consumed it yet (menu/cutscene/idle tick site). watchdog.
      BFG.stuck=(BFG.stuck or 0)+1
      if BFG.stuck&gt;=150 then
        local rearm=readQword(BFG.A.queue)
        if rearm and rearm~=0 and readInteger(BFG.A.done)==0 then
          if readQword(BFG.A.cosStore)~=0 then BFG.cq[#BFG.cq+1]=rearm else BFG.q[#BFG.q+1]=rearm end
        end
        writeInteger(BFG.A.flag,0); writeInteger(BFG.A.done,1); BFG.stuck=0
      end
      return
    end
    -- v0.1.4 done-handshake: the hook clears flag at the START of its insert but only sets done=1 when the
    -- insert FINISHES. Arming on flag==0 alone stomped the shared queue/record mid-insert and corrupted
    -- bundles (the whole "bundle/cosmetic crash"). Wait for done==1 (previous insert fully complete) first.
    if readInteger(BFG.A.done)==0 then
      BFG.stuck=(BFG.stuck or 0)+1
      if BFG.stuck&gt;=150 then writeInteger(BFG.A.done,1); BFG.stuck=0 end
      return
    end
    BFG.stuck=0
    -- ship customization (cosmetics / crew outfits) route to the customize-menu store, not the item bag
    if #BFG.cq&gt;0 then
      local st=BFG.findCosmeticStore()
      if not (st and st~=0) then return end
      local rec=BFG.cq[1]; local ok,h=pcall(readQword,rec+0x10); h=ok and h or 0
      -- v0.1.4 dedup: NEVER re-insert a cosmetic the store already owns. Rebuilding a duplicate item on an
      -- existing hash key corrupts it and crashes on the next store walk. Skip owned cosmetics silently.
      local dup=false
      pcall(function()
        local arr=readQword(st+0x14); local cnt=readInteger(st+0x1C)&amp;0x3FFF
        if arr and arr&gt;0x10000000000 then
          for i=0,cnt-1 do
            local P=readQword(arr+i*0x18); local T=(P and P&gt;0x10000000000) and readQword(P)
            local r=T and readQword(T+0x40); local hh=r and readQword(r+0x10)
            if hh==h then dup=true; break end
          end
        end
      end)
      table.remove(BFG.cq,1)
      if dup then return end
      writeQword(BFG.A.cosStore, st)
      writeQword(BFG.A.targetMgr, 0)
      writeQword(BFG.A.queue, rec)
      writeInteger(BFG.A.qcount, 1)
      writeInteger(BFG.A.done,0); writeInteger(BFG.A.flag,1)
      return
    end
    if #BFG.q==0 then return end
    local mgr=BFG.mgr or BFG.findMgr()
    if not (mgr and mgr~=0) then return end   -- keep items queued rather than delivering into a null target (silent loss)
    writeQword(BFG.A.targetMgr, mgr)
    writeQword(BFG.A.cosStore, 0)
    writeQword(BFG.A.queue, BFG.q[1])
    table.remove(BFG.q,1)
    writeInteger(BFG.A.qcount, 1)
    writeInteger(BFG.A.done,0); writeInteger(BFG.A.flag,1)
  end
end
function BFG.pending() return #BFG.q + (BFG.cq and #BFG.cq or 0) + ((BFG.A and readInteger(BFG.A.flag)==1) and readInteger(BFG.A.qcount) or 0) end
function BFG.give(hash, count)
  if not (BFG.A and getAddressSafe("bfgHook")) then if not BFG.installHook() then return -1 end end
  if not getAddressSafe("bfgTick") then BFG.installTick() end
  local rec=BFG.resolveRecord(hash); if not rec then return 0 end
  local reps=math.max(1,math.min(9999,tonumber(count) or 1))
  if BFG.isCosmetic(hash) then                 -- ship customization -&gt; store (else it lands in the bag, unusable)
    for _=1,reps do BFG.cq[#BFG.cq+1]=rec end
    return reps
  end
  local M=BFG.findMgr(); if not M then return -1 end
  BFG.mgr=M
  for _=1,reps do BFG.q[#BFG.q+1]=rec end
  return reps
end

gvGive = function(hash, count) return BFG.give(hash, count) end
if type(gvSetLevel)~='function' then gvSetLevel = function() return false end end

-- fresh-session hygiene
if BFG.pumpTimer then pcall(function() BFG.pumpTimer.destroy() end); BFG.pumpTimer=nil end
BFG.q={}
BFG.cq={}
BFG.cosSet=nil; BFG.cosStore=nil
BFG.mgr=nil
BFG.comparator=nil; BFG.cvt=nil   -- re-learn per launch (base/RVA can shift across game updates)
BFG.recCache={}
BFG.recIndex=nil; BFG.indexing=false
-- v0.1.5: only re-resolve AOBs on a genuinely new launch (ASLR gives a new module base). Re-resolving while
-- our own hooks are LIVE fails -- the giveItem/tick hooks overwrite those functions' signature bytes, so the
-- scan misses them and resolveAOB returns nil => "AOBs resolved: NO" on a same-process re-enable even though
-- the giver is installed and working. Keep the cached AOBs across a re-enable; only re-resolve per real launch.
if BFG.aobBase~=base then BFG.aob=nil; BFG.aobBase=base end
BFG.installHook()
BFG.installTick()           -- per-frame delivery hook
-- v0.1.4 tick-only delivery: the hook (on GiveItem) and the per-frame tick could both grab the same armed
-- item, and the tick's bag-give re-entered the hook -&gt; concurrent inserts corrupted the item. Force the
-- hook's flag-check (test eax,eax / je passthrough) to an unconditional jmp so ONLY the tick delivers.
pcall(function()
  local hb=getAddressSafe("bfgHook"); if not hb then return end
  for off=0x40,0x60 do
    local b=readBytes(hb+off,4,true)
    if b and b[1]==0x85 and b[2]==0xC0 and b[3]==0x0F and b[4]==0x84 then
      local je=hb+off+2; local rel=readInteger(je+2); local target=je+6+rel
      autoAssemble(string.format("%X:\njmp %X\nnop", je, target))
      break
    end
  end
end)
pcall(BFG.findMgr)
BFG.startPump()
BFG.buildIndex()
{$asm}

[DISABLE]
{$lua}
if syntaxcheck then return end
if BFG then if BFG.pumpTimer then pcall(function() BFG.pumpTimer.destroy() end); BFG.pumpTimer=nil end; pcall(BFG.uninstallHook) end
gvGive = nil
{$asm}
</AssemblerScript>
              <CheatEntries>
                <CheatEntry>
                  <ID>12</ID>
                  <Description>"★ OPEN INVENTORY EDITOR"</Description>
                  <VariableType>Auto Assembler Script</VariableType>
                  <AssemblerScript>[ENABLE]
{$lua}
if syntaxcheck then return end
local function bfUntick(id)
  local t=createTimer(nil,false); t.Interval=80
  t.OnTimer=function(tm) tm.destroy(); pcall(function()
    local r=getAddressList():getMemoryRecordByID(id); if r then r.Active=false end end) end
  t.Enabled=true
end
local function readTF(name)
  if type(findTableFile)~="function" then return nil end
  local ok,tf=pcall(findTableFile,name); if not (ok and tf) then return nil end
  local okd,data=pcall(function() return tf.getData and tf.getData() end)
  if okd and type(data)=="table" and #data&gt;0 then local c={} for i=1,#data do c[i]=string.char(data[i]) end return table.concat(c) end
  local oks,st=pcall(function() return tf.Stream end)
  if oks and st then
    pcall(function() st.Position=0 end)
    local okr,r=pcall(function() return st.read(st.Size) end)
    if okr and r then
      if type(r)=="table" then local c={} for i=1,#r do c[i]=string.char(r[i]) end return table.concat(c)
      elseif type(r)=="string" then return r end
    end
  end
  return nil
end
local src=readTF("bfEditor.lua")
local loaderr
if src then local fn,e=load(src)
  if fn then local ok2,e2=pcall(fn); if not ok2 then loaderr=e2 end else loaderr=e end
end
if type(gvOpenEditor)=='function' then gvOpenEditor()
elseif loaderr then showMessage("Inventory editor failed to start (editor code error):\n"..tostring(loaderr))
elseif src then showMessage("The editor file loaded but did not register its window (gvOpenEditor missing). Re-download the full, current .CT.")
else showMessage("Inventory editor code (bfEditor.lua) was not found in this table. Re-download the full .CT so the embedded editor file is included, or update Cheat Engine to 7.x.") end
bfUntick(12)   -- momentary button: opens the window, then un-ticks itself
{$asm}

[DISABLE]
{$lua}
if syntaxcheck then return end
-- no-op: the editor window has its own close (X) button; un-ticking must not close it.
{$asm}
</AssemblerScript>
                </CheatEntry>
              </CheatEntries>
            </CheatEntry>
          </CheatEntries>
        </CheatEntry>
      </CheatEntries>
    </CheatEntry>
  </CheatEntries>
  <UserdefinedSymbols/>
</CheatTable>
