    <File Name="bf_Bundles.txt" Encoding="Ascii85">ZIo=q,CU7*])_)YDJ*gmS[u#j=I?KtDUhVF0j(sXUrvS=awEB+yQ2):FT8ItU#PU=3WA^A+=-%:@ZD/mi.FAhr={ienBp21I}k]0TVBu(fG{4Xng?VqYca**jzcdRwrcj-t}DBs%PSb7PDlePf_W;9ia_+5!g),QlMo0*SzTf#/eGK0hHGyC^evOst9-9X-GGQm8nF[jS(n]5$xB1MZeN80[J0o^a^}u5HpXK0%f:r0x=%p98tB_wA7F^nS{lmxGTd%CBlc+)oU??:m_T6*(?U=0U}mCC.Y0xCp)vb1([IG3zJF]k_AeK_e9yJoYAH:26r71:@1v$qUIE{+Ct{OWTQWCrgjXSB?F}kBXcQ?EPWlKVxgsSog$e#9Z4PXo;^!t#k-?Q0n@^u%;J.Q%bDt2U;;eTmX1a3CuPd=MDM_:q-tp.8q-@Qaa,9EpH7phF0gYjq%V97cLpYiRMb@ir^j?u,=x5%UcVSp7F9i3UPG!OOe8-_4w5k?{wqLafoA)8-h;)A3%LiNnW;,V/-0*%jhsH%bEeR#Rg+$a9Q}RlKLv_xtBDbeYERwukaBy(q84B]o$_??x^*J=oRTxEq2T=G44yN.Sl-fOqQaf{h@(LvS=@5cylx[:3zQQ(4NyM$0l]y?cQX+GpQN57L[[hh[M%,((T0bx+2.@IS[(^pDQ=lqSG#]5F6g{DsB{_nUXT-O23C{]VzcMs]/}:?5A){tUCg-T#cHQ3UI?E%W,go:IwNA@WHYlh}P#aQw]!tUgo)IK^y7tF_dcKzw-/%+m:4lLbKI.m.V8P(uD[R2A-zmYvVy+{@SO0/DYe9/f]8n(cJxkY7+NYGpVyBV%]4qg(YvM)AFnUqM-[i68vaijKi;(V:;$:E#F0wlZS+v.Z4+</File>
  </Files>
  <CheatEntries>
    <CheatEntry>
      <ID>1</ID>
      <Description>"Attach to Game (Auto-Detect) | ENABLE THIS FIRST"</Description>
      <VariableType>Auto Assembler Script</VariableType>
      <AssemblerScript>[ENABLE]
{$lua}
if syntaxcheck then return end
-- (auto-update checker removed for FearlessRevolution compliance: no network calls, no version fetch, no external links)

-- ---- universal attach (Steam / Ubisoft Connect = ACBlackFlag.exe, Ubisoft+ = ACBlackFlag_Plus.exe) ----
local EXE_STANDARD = "ACBlackFlag.exe"
local EXE_PLUS     = "ACBlackFlag_Plus.exe"
local detectedExe = nil
if getProcessIDFromProcessName(EXE_STANDARD) then openProcess(EXE_STANDARD); detectedExe=EXE_STANDARD
elseif getProcessIDFromProcessName(EXE_PLUS) then openProcess(EXE_PLUS); detectedExe=EXE_PLUS
else print("Black Flag process not found - launch the game first.") end
if detectedExe then
  local base = getAddress(detectedExe)
  print("Attached to "..detectedExe.."  base="..(base and string.format("%X",base) or "?"))
  if base and base~=0 then
    local other = (detectedExe==EXE_STANDARD) and EXE_PLUS or EXE_STANDARD
    pcall(unregisterSymbol, other); pcall(registerSymbol, other, base, true)
  end
end
-- (no update check on attach - removed for FRF compliance)
{$asm}

[DISABLE]
</AssemblerScript>
    </CheatEntry>
    <CheatEntry>
      <ID>10</ID>
      <Description>"Inventory Options"</Description>
      <Options moManualExpandCollapse="1"/>
      <GroupHeader>1</GroupHeader>
      <CheatEntries>
        <CheatEntry>
          <ID>11</ID>
          <Description>"Item Giver | ENABLE FIRST (finds your inventory)"</Description>
          <VariableType>Auto Assembler Script</VariableType>
          <AssemblerScript>[ENABLE]
{$lua}
if syntaxcheck then return end
BFG = BFG or {}
BFG.base = getAddress("ACBlackFlag.exe")
local base = BFG.base
local function say(s) end  -- silent (no Lua-console output in the release)
local function heap(p) return p and p&gt;0x10000000000 and p&lt;0x7FF000000000 end
local function le8(v) local t={} for i=0,7 do t[#t+1]=string.format("%02X",(v&gt;&gt;(8*i))&amp;0xFF) end return table.concat(t," ") end

-- ---------- the give hook (construct our item + GiveItem to the found mgr) ----------
function BFG.installHook()
  -- restore prologue if a prior hook is present, then (re)assemble a fresh stub
  pcall(function() writeBytes(base+0xFE8BE0, 0x41,0x57,0x41,0x56,0x41,0x54) end)
  pcall(function() autoAssemble([[
dealloc(bfgHook)
unregistersymbol(bfgHook)
]]) end)
  local stub = [[
alloc(bfgHook,8192,ACBlackFlag.exe+FE8BE0)
label(bfgMgr) label(bfgNatReq) label(bfgFlag) label(bfgDone) label(bfgRec) label(bfgItem) label(bfgReq) label(bfgTargetMgr) label(bfgQCount) label(bfgQueue)
label(ppool) label(qloop) label(qnext) label(qdone) label(pass)
registersymbol(bfgHook)
bfgHook:
  mov [bfgMgr],rcx
  mov [bfgNatReq],rdx
  mov eax,[bfgFlag]
  test eax,eax
  je pass
  xor eax,eax
  mov [bfgFlag],eax
  push r15
  push r13
  push rax
  push rcx
  push rdx
  push r8
  push r9
  push r10
  push r11
  push r14
  pushfq
  xor r15,r15
  lea r13,[bfgQueue]
qloop:
  mov eax,[bfgQCount]
  cmp r15d,eax
  jge qdone
  mov rax,[r13+r15*8]
  mov [bfgRec],rax
  mov r8,gs:[58]
  mov ecx,[ACBlackFlag.exe+AB25820]
  mov r8,[r8+rcx*8]
  mov rax,[r8+1C60]
  test rax,rax
  jnz ppool
  mov rax,[ACBlackFlag.exe+AF08C78]
ppool:
  mov rcx,rax
  mov edx,88
  mov r8d,8
  call ACBlackFlag.exe+41CCE40
  test rax,rax
  jz qnext
  mov r14,rax
  xor eax,eax
  mov [r14+08],eax
  mov eax,[r14+38]
  and eax,80000000
  or eax,0000C000
  mov [r14+38],eax
  mov eax,[r14+20]
  and eax,80000000
  or eax,0000C000
  mov [r14+20],eax
  xor eax,eax
  mov [r14+18],rax
  vxorps xmm0,xmm0,xmm0
  vmovups [r14+28],xmm0
  mov rax,ACBlackFlag.exe+93870D0
  mov [r14+00],rax
  mov rax,ACBlackFlag.exe+9281458
  mov [r14+10],rax
  mov rax,ACBlackFlag.exe+AF0C998
  mov [r14+40],rax
  mov [r14+58],rax
  xor eax,eax
  mov [r14+60],eax
  mov eax,[r14+6C]
  and eax,80000000
  or eax,0000C000
  mov [r14+6C],eax
  xor eax,eax
  mov [r14+64],rax
  mov [r14+70],al
  mov rax,ACBlackFlag.exe+AF0C998
  mov [r14+78],rax
  vmovups [r14+48],xmm0
  mov eax,FFFFFFFF
  db F2 49 0F 38 F1 C6
  not eax
  mov [r14+80],eax
  mov rcx,r14
  lea rdx,[bfgRec]
  call ACBlackFlag.exe+4319E0
  mov [bfgItem],r14
  mov [bfgReq+08],r14
  mov rcx,[bfgTargetMgr]
  test rcx,rcx
  jz qnext
  lea rdx,[bfgReq]
  sub rsp,20
  call ACBlackFlag.exe+FE8BE0
  add rsp,20
qnext:
  inc r15
  jmp qloop
qdone:
  xor eax,eax
  mov [bfgQCount],eax
  mov eax,1
  mov [bfgDone],eax
  popfq
  pop r14
  pop r11
  pop r10
  pop r9
  pop r8
  pop rdx
  pop rcx
  pop rax
  pop r13
  pop r15
pass:
  push r15
  push r14
  push r12
  jmp ACBlackFlag.exe+FE8BE6
bfgMgr:
  dq 0
bfgNatReq:
  dq 0
bfgFlag:
  dd 0
bfgDone:
  dd 0
bfgRec:
  dq 0
bfgItem:
  dq 0
bfgTargetMgr:
  dq 0
bfgReq:
  dd 3F800000
  dd 0
  dq 0
  dq 0
  dd 01010101
  dd 0
bfgQCount:
  dd 0
  dd 0
bfgQueue:
  dq 0
]]
  local ok,err = autoAssemble(stub)
  local H = getAddressSafe("bfgHook")
  if not ok or not H then say("hook assemble failed: "..tostring(err)); return false end
  -- recover data addresses from the code (CE drops the data symbols): first insn
  -- is `mov [bfgMgr],rcx` = 48 89 0D &lt;rel32&gt;  -&gt;  bfgMgr = H+7+rel32
  local b = readBytes(H,3,true)
  if not (b[1]==0x48 and b[2]==0x89 and b[3]==0x0D) then say("hook layout unexpected"); return false end
  local rel = readInteger(H+3); if rel&gt;=0x80000000 then rel=rel-0x100000000 end
  local m = (H+7+rel) &amp; 0xFFFFFFFFFFFFFFFF
  BFG.A = { hook=H, mgr=m, natreq=m+0x08, flag=m+0x10, done=m+0x14, rec=m+0x18, item=m+0x20, targetMgr=m+0x28, req=m+0x30, qcount=m+0x50, queue=m+0x58 }
  -- write req fields explicitly (do not rely on CE dd parsing)
  writeInteger(BFG.A.req+0x00, 0x3F800000)   -- amount 1.0f
  writeInteger(BFG.A.req+0x04, 0)
  writeQword  (BFG.A.req+0x08, 0)
  writeQword  (BFG.A.req+0x10, 0)
  writeInteger(BFG.A.req+0x18, 0x01010101)
  writeInteger(BFG.A.req+0x1C, 0)
  writeInteger(BFG.A.flag,0); writeInteger(BFG.A.done,0); writeQword(BFG.A.targetMgr,0); writeInteger(BFG.A.qcount,0)
  -- two-phase: only write the jmp after the prologue is confirmed intact
  local give=base+0xFE8BE0
  local pre=readBytes(give,6,true)
  if not (pre[1]==0x41 and pre[2]==0x57 and pre[3]==0x41 and pre[4]==0x56 and pre[5]==0x41 and pre[6]==0x54) then
    say("GiveItem prologue not as expected -- ABORT"); return false
  end
  local r2=(H-(give+5))&amp;0xFFFFFFFF
  writeBytes(give,0xE9,r2&amp;0xFF,(r2&gt;&gt;8)&amp;0xFF,(r2&gt;&gt;16)&amp;0xFF,(r2&gt;&gt;24)&amp;0xFF,0x90)
  return true
end

function BFG.uninstallHook()
  pcall(function() writeBytes(base+0xFE8BE0, 0x41,0x57,0x41,0x56,0x41,0x54) end)
  pcall(function() autoAssemble([[
dealloc(bfgHook)
unregistersymbol(bfgHook)
]]) end)
  BFG.A=nil
end

-- ---------- auto-find the real player inventory manager (unique fingerprint) ----------
local function mgrValid(M)
  local ok,gate=pcall(readQword,M+8); if not ok or gate~=0 then return false end
  if readQword(M+0x88)~=M+0xB0 then return false end
  if readQword(M+0x20)~=base+0x4B0F010 then return false end
  local cnt=readInteger(M+0x1C); local arr=readQword(M+0x14)
  return cnt and (cnt&amp;0x3FFF)&gt;10 and (cnt&amp;0x3FFF)&lt;4096 and heap(arr)
end
function BFG.findMgr()
  if BFG.mgr and mgrValid(BFG.mgr) then return BFG.mgr end   -- cached + still valid
  local s=AOBScan(le8(base+0x4B0F010),"+W-X"); if not s then return nil end
  local best,bestCnt=nil,0
  for i=0,s.Count-1 do
    local M=tonumber(s[i],16)-0x20
    if mgrValid(M) then local c=readInteger(M+0x1C)&amp;0x3FFF; if c&gt;bestCnt then best=M; bestCnt=c end end
  end
  s.destroy(); BFG.mgr=best; return best
end

-- ---------- hash -&gt; resident catalog record  (cached + record-chunk-bounded scan) ----------
-- Derive a record chunk from a manager item (template+0x40) and scan just there (~150 ms), with
-- a full-scan fallback for records elsewhere, then cache. Per-give scan -- NO background index
-- thread (that thread starved the delivery pump = the "new version won't give" bug). Repeats cached.
BFG.recCache = BFG.recCache or {}
local function recRegion()
  local M=BFG.findMgr(); if not M then return nil end
  local arr=readQword(M+0x14); local P=arr and readQword(arr)
  local T=(P and P&gt;0x10000000000) and readQword(P) or nil
  local rr=T and readQword(T+0x40)
  if rr and rr&gt;0x10000000000 then local lo=rr &amp; 0xFFFFF0000000; return lo, lo+0x40000000 end
  return nil
end
local function scanRec(hash, lo, hi)
  local CVT=base+0x93875C0; local rec
  local ms=createMemScan(); ms.setOnlyOneResult(false)
  pcall(function()
    if lo then ms.firstScan(soExactValue,vtByteArray,rtRounded,le8(hash),nil,lo,hi,"+W-X",fsmNotAligned,"",true,false,false,false)
    else ms.firstScan(soExactValue,vtByteArray,rtRounded,le8(hash),nil,0,0x7fffffffffff,"+W-X",fsmNotAligned,"",true,false,false,false) end
    ms.waitTillDone(); local fl=createFoundList(ms); fl.initialize()
    for i=0,fl.Count-1 do local r=tonumber(fl.Address[i],16)-0x10
      local ok,cd=pcall(readQword,r); local ok2,bb=pcall(readBytes,r+0x0B,1,false)
      if ok and ok2 and cd and cd&gt;0x10000 then local ok3,vt=pcall(readQword,cd)
        if ok3 and vt==CVT and bb and (bb&amp;0x80)~=0 then rec=r break end end end
    fl.destroy()
  end); ms.destroy(); return rec
end
-- COMPLETE hash-&gt;record index, built ONCE in the background (safe: the persistent main-thread
-- pump keeps delivering during the build -- proven). Once built every resolve is instant (0ms),
-- so bundles are near-instant instead of 6x a per-item memory scan.
BFG.recIndex = BFG.recIndex
BFG.indexing = false
function BFG.buildIndex()
  if BFG.indexing or BFG.recIndex then return end
  BFG.indexing=true
  createThread(function()
    local CVT=base+0x93875C0; local idx={}
    pcall(function()
      local ms=createMemScan(); ms.setOnlyOneResult(false)
      ms.firstScan(soExactValue,vtQword,rtRounded,string.format("%X",CVT),nil,0,0x7fffffffffff,"+W-X",fsmAligned,"",true,false,false,false)
      ms.waitTillDone(); local fl=createFoundList(ms); fl.initialize()
      local lo,hi
      for i=0,fl.Count-1 do local a=tonumber(fl.Address[i],16); if not lo or a&lt;lo then lo=a end; if not hi or a&gt;hi then hi=a end end
      fl.destroy(); ms.destroy()
      if lo then
        local m2=createMemScan(); m2.setOnlyOneResult(false)
        m2.firstScan(soValueBetween,vtQword,rtRounded,string.format("%X",lo),string.format("%X",hi),0,0x7fffffffffff,"+W-X",fsmAligned,"",true,false,false,false)
        m2.waitTillDone(); local f2=createFoundList(m2); f2.initialize()
        for i=0,f2.Count-1 do local r=tonumber(f2.Address[i],16)
          local ok,cd=pcall(readQword,r); if ok and cd and cd&gt;=lo and cd&lt;=hi then local ok2,vt=pcall(readQword,cd)
            if ok2 and vt==CVT then local ok3,b=pcall(readBytes,r+0x0B,1,false)
              if ok3 and b and (b&amp;0x80)~=0 then idx[readQword(r+0x10)]=r end end end end
        f2.destroy(); m2.destroy()
      end
    end)
    BFG.recIndex=idx; BFG.indexing=false
  end)
end
function BFG.resolveRecord(hash)
  if type(hash)=="string" then hash=tonumber(hash,16) end
  if BFG.recIndex and BFG.recIndex[hash] then return BFG.recIndex[hash] end   -- instant (index)
  if BFG.recCache[hash] then return BFG.recCache[hash] end
  local lo,hi=recRegion()                                                     -- fallback if index not built yet
  local rec = lo and scanRec(hash,lo,hi)
  if not rec then rec=scanRec(hash,nil,nil) end
  if rec then BFG.recCache[hash]=rec end
  return rec
end

-- ---------- non-blocking delivery queue ----------
-- give(hash[,count]) RESOLVES (fast, cached) + QUEUES; a pump timer arms items one at a
-- time and the hook delivers each on the game's next GiveItem. No busy-wait -&gt; no stutter,
-- no UI freeze, accurate progress. give() returns: reps queued / 0 unresolved / -1 no mgr.
BFG.q = BFG.q or {}
-- PERSISTENT pump. MUST be created on the MAIN thread (call from enable) -- a CE timer created
-- inside the editor's worker thread (startPump-on-give) is DEAD and never ticks =&gt; stuck queue,
-- "delivering N left forever". It keeps ticking (never self-destructs) so it always drains new work.
function BFG.startPump()
  if BFG.pumpTimer then return end
  BFG.pumpTimer=createTimer(getMainForm()); BFG.pumpTimer.Interval=20
  BFG.pumpTimer.OnTimer=function(tm)
    if not (BFG.A and getAddressSafe("bfgHook")) then return end
    if readInteger(BFG.A.flag)~=0 then return end          -- hook still delivering the last batch
    if #BFG.q==0 then return end                            -- nothing queued; keep ticking
    local n=math.min(#BFG.q, 1)                             -- SINGLE item per event (confirmed-stable). Batching (&gt;1) can crash on big gives; the per-frame hook is the real fix for fast bundles.
    writeQword(BFG.A.targetMgr, BFG.mgr or BFG.findMgr() or 0)
    for i=1,n do writeQword(BFG.A.queue + (i-1)*8, BFG.q[i]) end
    for _=1,n do table.remove(BFG.q,1) end
    writeInteger(BFG.A.qcount, n)
    writeInteger(BFG.A.done,0); writeInteger(BFG.A.flag,1)
  end
end
function BFG.pending() return #BFG.q + ((BFG.A and readInteger(BFG.A.flag)==1) and readInteger(BFG.A.qcount) or 0) end
function BFG.give(hash, count)
  if not (BFG.A and getAddressSafe("bfgHook")) then if not BFG.installHook() then return -1 end end
  local M=BFG.findMgr(); if not M then return -1 end
  BFG.mgr=M
  local rec=BFG.resolveRecord(hash); if not rec then return 0 end
  local reps=math.max(1,math.min(9999,tonumber(count) or 1))
  for _=1,reps do BFG.q[#BFG.q+1]=rec end
  -- do NOT startPump here: give() runs in the editor's worker thread; the pump is created on
  -- enable (main thread) and delivers whatever we queue. Creating it here makes a dead timer.
  return reps
end

-- editor hook: gvGive(hash[,count]) is what the GUI calls
gvGive = function(hash, count) return BFG.give(hash, count) end
-- no item levels in Black Flag: gvSetLevel is a harmless no-op so shared GUI code stays happy
if type(gvSetLevel)~='function' then gvSetLevel = function() return false end end

-- fresh-session hygiene: the manager + record addresses change every game launch, and a CE timer
-- dies across a table reload while BFG persists -&gt; a dead pump makes gives pile up ("delivering N
-- left forever"). Drop the stale pump/queue + the per-session caches so each enable self-heals.
if BFG.pumpTimer then pcall(function() BFG.pumpTimer.destroy() end); BFG.pumpTimer=nil end
BFG.q={}
BFG.mgr=nil
BFG.recCache={}
BFG.recIndex=nil; BFG.indexing=false   -- rebuild the record index for THIS session (addresses change per game launch)
BFG.installHook()
pcall(BFG.findMgr)   -- warm the manager cache for a fast first give
BFG.startPump()      -- create the delivery pump NOW, on the main thread, so it actually ticks
BFG.buildIndex()     -- background index build (~25s); the pump keeps delivering during it (proven). Bundles become near-instant once built.
{$asm}

[DISABLE]
{$lua}
if syntaxcheck then return end
if BFG then if BFG.pumpTimer then pcall(function() BFG.pumpTimer.destroy() end); BFG.pumpTimer=nil end; pcall(BFG.uninstallHook) end
gvGive = nil
{$asm}
</AssemblerScript>
        </CheatEntry>
        <CheatEntry>
          <ID>12</ID>
          <Description>"★ OPEN INVENTORY EDITOR"</Description>
          <VariableType>Auto Assembler Script</VariableType>
          <AssemblerScript>[ENABLE]
{$lua}
if syntaxcheck then return end
local function bfUntick(id)
  local t=createTimer(nil,false); t.Interval=80
  t.OnTimer=function(tm) tm.destroy(); pcall(function()
    local r=getAddressList():getMemoryRecordByID(id); if r then r.Active=false end end) end
  t.Enabled=true
end
local function readTF(name)
  if findTableFile then local ok,tf=pcall(findTableFile,name)
    if ok and tf then local st=tf.Stream; if st then st.Position=0; local r=st.read(st.Size)
      if type(r)=="table" then local c={} for i=1,#r do c[i]=string.char(r[i]) end return table.concat(c)
      elseif type(r)=="string" then return r end end end end
  return nil
end
local src=readTF("bfEditor.lua")
if src then local fn=load(src); if fn then pcall(fn) end end
if type(gvOpenEditor)=='function' then gvOpenEditor() else showMessage("Editor code not found (embed bfEditor.lua as a table file, or keep it in the dev folder).") end
bfUntick(12)   -- momentary button: opens the window, then un-ticks itself
{$asm}

