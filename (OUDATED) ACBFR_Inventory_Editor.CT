  </Files>
  <CheatEntries>
    <CheatEntry>
      <ID>1</ID>
      <Description>"Attach to Game (Auto-Detect) | Cheat Table Made By JenAriDev"</Description>
      <Options moHideChildren="1"/>
      <VariableType>Auto Assembler Script</VariableType>
      <AssemblerScript>[ENABLE]
{$lua}
if syntaxcheck then return end
-- (auto-update checker removed for FearlessRevolution compliance: no network calls, no version fetch, no external links)

-- ---- universal attach (Steam / Ubisoft Connect = ACBlackFlag.exe, Ubisoft+ = ACBlackFlag_Plus.exe) ----
local EXE_STANDARD = "ACBlackFlag.exe"
local EXE_PLUS     = "ACBlackFlag_Plus.exe"
local detectedExe = nil
if getProcessIDFromProcessName(EXE_STANDARD) then openProcess(EXE_STANDARD); detectedExe=EXE_STANDARD
elseif getProcessIDFromProcessName(EXE_PLUS) then openProcess(EXE_PLUS); detectedExe=EXE_PLUS
else print("Black Flag process not found - launch the game first.") end
if detectedExe then
  local base = getAddress(detectedExe)
  print("Attached to "..detectedExe.."  base="..(base and string.format("%X",base) or "?"))
  if base and base~=0 then
    local other = (detectedExe==EXE_STANDARD) and EXE_PLUS or EXE_STANDARD
    pcall(unregisterSymbol, other); pcall(registerSymbol, other, base, true)
  end
end
-- (no update check on attach - removed for FRF compliance)
{$asm}

[DISABLE]
</AssemblerScript>
      <CheatEntries>
        <CheatEntry>
          <ID>23</ID>
          <Description>"Player Options"</Description>
          <Options moHideChildren="1"/>
          <GroupHeader>1</GroupHeader>
          <CheatEntries>
            <CheatEntry>
              <ID>22</ID>
              <Description>"God Mode"</Description>
              <VariableType>Auto Assembler Script</VariableType>
              <AssemblerScript>[ENABLE]
aobscanmodule(bfGodHP,ACBlackFlag.exe,C5 FA 11 81 98 01 00 00 C5 FA 11 40 18)
alloc(bfGodCave,256,bfGodHP)
label(bfGodRet)
registersymbol(bfGodHP)

bfGodCave:
vmaxss xmm0,xmm0,[rcx+198]
vmovss [rcx+198],xmm0
jmp bfGodRet

bfGodHP:
jmp bfGodCave
nop 3
bfGodRet:

[DISABLE]
bfGodHP:
db C5 FA 11 81 98 01 00 00
dealloc(bfGodCave)
unregistersymbol(bfGodHP)
</AssemblerScript>
            </CheatEntry>
          </CheatEntries>
        </CheatEntry>
        <CheatEntry>
          <ID>10</ID>
          <Description>"Inventory Options"</Description>
          <Options moHideChildren="1" moManualExpandCollapse="1"/>
          <GroupHeader>1</GroupHeader>
          <CheatEntries>
            <CheatEntry>
              <ID>20</ID>
              <Description>"Universal Resource (add on use / consume / buy)"</Description>
              <Options moHideChildren="1"/>
              <VariableType>Auto Assembler Script</VariableType>
              <AssemblerScript>[ENABLE]
alloc(bfgURcave,0x400,ACBlackFlag.exe+F4DE0B)
alloc(bfgUR_value,4)
registersymbol(bfgUR_value)
label(bfgUR_ret)
label(bfgURhook)

bfgUR_value:
dd 0

bfgURcave:
bfgURhook:
mov edx,[rbx+r14+10]
add edx,[bfgUR_value]
mov [rbx+r14+10],edx
jmp bfgUR_ret

ACBlackFlag.exe+F4DE0B:
jmp bfgURhook
bfgUR_ret:

[DISABLE]
ACBlackFlag.exe+F4DE0B:
db 42 89 54 33 10

unregistersymbol(bfgUR_value)
dealloc(bfgUR_value)
dealloc(bfgURcave)
</AssemblerScript>
              <CheatEntries>
                <CheatEntry>
                  <ID>21</ID>
                  <Description>"Set value / how it works  (click me)"</Description>
                  <VariableType>Auto Assembler Script</VariableType>
                  <AssemblerScript>[ENABLE]
{$lua}
if syntaxcheck then return end
local function bfUntick(id)
  local t=createTimer(nil,false); t.Interval=80
  t.OnTimer=function(tm) tm.destroy(); pcall(function()
    local r=getAddressList():getMemoryRecordByID(id); if r then r.Active=false end end) end
  t.Enabled=true
end
local sym="bfgUR_value"
if not getAddressSafe(sym) then
  showMessage("Enable the parent \"Universal Resource\" cheat first, then set the amount.")
else
  local cur=readInteger(sym)
  local s=inputQuery("Universal Resource",
    "Whenever you USE / CONSUME / BUY an item, its amount is set to (current + this value) instead of dropping.\n\n    0  =  infinite  (amounts never decrease)\n    N  =  add N to that item's total each use\n\nEnter a value:",
    tostring(cur or 0))
  if s and tonumber(s) then
    local n=math.floor(tonumber(s)); if n&lt;0 then n=0 end
    writeInteger(sym,n)
    showMessage(n==0 and "Set to 0  --  amounts are now infinite (they never decrease)." or ("Set to "..n.."  --  adds "..n.." to that item's total each use."))
  end
end
bfUntick(21)
